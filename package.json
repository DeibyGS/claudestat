{
  "name": "@deibygs/claudestat",
  "version": "0.2.5",
  "description": "Real-time execution trace and cost intelligence for Claude Code",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "cli",
    "monitoring",
    "cost",
    "token",
    "dashboard"
  ],
  "homepage": "https://github.com/DeibyGS/claudestat#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeibyGS/claudestat.git"
  },
  "bugs": {
    "url": "https://github.com/DeibyGS/claudestat/issues"
  },
  "license": "MIT",
  "files": [
    "dist/",
    "hooks/",
    "dashboard/dist/"
  ],
  "bin": {
    "claudestat": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:dashboard",
    "build:dashboard": "cd dashboard && npm install && npm run build",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build",
    "dev": "tsx src/index.ts",
    "dev:full": "tsx src/index.ts start & sleep 1 && cd dashboard && npm run dev",
    "start": "node dist/index.js",
    "test": "CLAUDESTAT_DB_PATH=:memory: CLAUDESTAT_DATA_DIR=/tmp ${NVM_BIN:-$(dirname $(which node))}/node --require tsx/cjs tests/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
